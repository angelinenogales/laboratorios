#include <iostream>
#include <cmath>
using namespace std;

int main() {

    float x, resultado = 1;
    int n;

    cout << "Ingrese el valor de x: ";
    cin >> x;

    cout << "Ingrese la cantidad de terminos n: ";
    cin >> n;

    long long factorial;
    int exponente;

    for(int i = 1; i < n; i++) {

        exponente = 2 * i;   // 2, 4, 6, 8...

        factorial = 1;

        for(int j = 1; j <= exponente; j++) {
            factorial = factorial * j;
        }

        resultado = resultado + (pow(x, exponente) / factorial);
    }

    cout << "\nAproximacion de cosh(" << x << ") = " << resultado << endl;

    return 0;
}
