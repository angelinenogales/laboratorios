#include <iostream>
using namespace std;

int esPrimo(int n) {

    if(n < 2) return 0;

    for(int i = 2; i * i <= n; i++) {

        if(n % i == 0) return 0;

    }

    return 1;
}

int siguientePrimo(int n) {

    do {
        n++;
    } while(!esPrimo(n));

    return n;
}

int main() {

    int n;
    long long f0 = 1, f1 = 1, fn;
    int primo = 2;

    cout << "Ingrese la cantidad de terminos: ";
    cin >> n;

    cout << "\nSerie:" << endl;

    for(int i = 1; i <= n; i++) {

        if(i == 1) {

            fn = f0;

        } else if(i == 2) {

            fn = f1;

        } else {

            fn = f0 + f1;
            f0 = f1;
            f1 = fn;

        }

        // asegurar denominador primo
        if(i > 1) {
            primo = siguientePrimo(primo);
        }

        cout << fn << "/" << primo << endl;
    }

    return 0;
}
