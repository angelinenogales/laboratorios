#include <iostream>
using namespace std;

int main() {

    int pin, copia, digito, anterior;
    int intentos = 0;
    bool valido;

    while(intentos < 3) {

        valido = true;

        cout << "Ingrese su PIN de 4 digitos: ";
        cin >> pin;

        copia = pin;

        int cantidad = 0;
        anterior = -1;

        while(copia > 0) {

            digito = copia % 10;
            cantidad++;

            if(digito == anterior) {
                valido = false;
            }

            anterior = digito;
            copia = copia / 10;
        }

        if(cantidad != 4) {
            valido = false;
        }

        if(valido) {

            cout << "PIN valido" << endl;
            return 0;

        } else {

            cout << "PIN invalido" << endl;
            intentos++;

        }

    }

    cout << "Cuenta bloqueada" << endl;

    return 0;
}
