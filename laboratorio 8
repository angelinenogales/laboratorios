#include <iostream>
using namespace std;

int main() {

    int numero, digito;
    int suma = 0, contador = 0, mayores5 = 0;
    float promedio;

    cout << "Ingrese el numero que representa el uso de aplicaciones: ";
    cin >> numero;

    while(numero > 0) {

        digito = numero % 10;

        suma = suma + digito;
        contador++;

        if(digito > 5) {
            mayores5++;
        }

        numero = numero / 10;
    }

    if(contador > 0) {
        promedio = (float)suma / contador;
    } else {
        promedio = 0;
    }

    cout << "\nTotal de horas: " << suma << endl;
    cout << "Aplicaciones con mas de 5 horas: " << mayores5 << endl;
    cout << "Promedio de horas: " << promedio << endl;

    return 0;
}
