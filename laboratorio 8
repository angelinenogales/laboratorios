#include <iostream>
using namespace std;

int main() {

    int numero, digito;
    int maximo, minimo;
    int contadorMax = 0;

    cout << "Ingrese el numero que representa el consumo diario: ";
    cin >> numero;

    // Inicializar con el primer digito
    digito = numero % 10;
    maximo = digito;
    minimo = digito;
    contadorMax = 1;

    numero = numero / 10;

    while(numero > 0) {

        digito = numero % 10;

        // Maximo
        if(digito > maximo) {
            maximo = digito;
            contadorMax = 1;
        }
        else if(digito == maximo) {
            contadorMax++;
        }

        // Minimo
        if(digito < minimo) {
            minimo = digito;
        }

        numero = numero / 10;
    }

    cout << "\nMayor consumo (maximo): " << maximo << " GB" << endl;
    cout << "Menor consumo (minimo): " << minimo << " GB" << endl;
    cout << "Repeticiones del maximo: " << contadorMax << endl;

    return 0;
}
