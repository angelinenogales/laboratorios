#include <stdio.h>
#include<math.h>

int main()
{
  float radio,altura,area,volumen,suma;
  const float PI=3.1416;
   printf("CALCULO DE GEOMETRIA DEL CILINDRO\n");
  printf("ingrese el valor del radio(r)");
  scanf("%f",&radio);
  printf("Ingrese el valor de la altura(h)");
  scanf("%f",&altura);
  area=2*PI*radio*altura;
  volumen=PI*pow(radio,2)*altura;
  suma=area+volumen;
   printf("RESULTADOS CALCULADOS:\n");
   printf("-------------------------------------\n");
  printf("Radio ingresado: %.2f\n",radio);
  printf("Altura ingresado: %.2f\n",altura);
   printf("-------------------------------------\n");
  printf("Area lateral:%.4f\ unidades cuadradas\n",area);
  printf("volumen:  %.4f\n unidades cubicas\n",volumen);
   printf("suma del volumen y radio es: %.4f\n ",suma);
  
    return 0;
}
