#include <iostream>
using namespace std;

int main() {

    float a, b, resultado;
    int opcion;

    cout << "Ingrese dos numeros: ";
    cin >> a >> b;

    cout << "\nSeleccione operacion:" << endl;
    cout << "1. Suma" << endl;
    cout << "2. Resta" << endl;
    cout << "3. Multiplicacion" << endl;
    cout << "4. Division" << endl;

    cout << "Opcion: ";
    cin >> opcion;

    switch(opcion) {

        case 1:
            resultado = a + b;
            cout << "Resultado: " << resultado << endl;
            break;

        case 2:
            resultado = a - b;
            cout << "Resultado: " << resultado << endl;
            break;

        case 3:
            resultado = a * b;
            cout << "Resultado: " << resultado << endl;
            break;

        case 4:

            if(b == 0) {
                cout << "Error: no se puede dividir entre cero" << endl;
            } else {
                resultado = a / b;
                cout << "Resultado: " << resultado << endl;
            }

            break;

        default:
            cout << "Opcion invalida" << endl;
    }

    return 0;
}

